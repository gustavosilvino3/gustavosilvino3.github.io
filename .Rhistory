gcl(5,10,m,a,0,unit=TRUE))
gcl <- function(n, x0, m, a, c, unit = TRUE) {
x <- vector()
x[1] <- x0
for(i in 2:(n+1)) {
x[i] <- (a * x[i - 1] + c) %% m
}
if(unit) x <- x/m
return(x[-1]) # exclui o primeiro - chute inicial
}
