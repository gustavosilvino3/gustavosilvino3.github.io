X1=c(0,0,1,1,2,2,3,3,4,4)
X2=c(1,0,1,0,1,2,1,2,1,1)
Y=c(5,6,6,7,7,8,8,9,7,7)
#a)
n=length(Y)
x1bar=mean(X1)
x2bar=mean(X2)
ybar=mean(Y)
S11=sum((X1-x1bar)^2)
S22=sum((X2-x2bar)^2)
S12=sum((X1-x1bar)*(X2-x2bar))
S1y=sum((X1-x1bar)*(Y-ybar))
S2y=sum((X2-x2bar)*(Y-ybar))
D=S11*S22-S12^2
D
b1=(S1y*S22-S2y*S12)/D
b2=(S2y*S11-S1y*S12)/D
b1
b2
b0=ybar-b1*x1bar-b2*x2bar
b0
#b)
yest=b0+b1*X1+b2*X2
yest=b0+b1*X1+b2*X2
yest
SQTotal=sum((Y-mean(Y))^2)
SQTotal
SQErro=sum((Y-yest)^2)
SQErro
SQReg=SQTotal-SQErro
SQReg
QMErro=SQErro/(length(Y)-3)
QMErro
QMReg=SQReg/2
QMReg
Fcalc=QMReg/QMErro
Fcalc
pvalor=1-pf(Fcalc,2,length(Y)-3)
pvalor
